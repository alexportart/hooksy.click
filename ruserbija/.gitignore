# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# data cache (scraped data, cookies, logs)
/data/
!/data/.gitkeep

# scripts (runtime deps for ts-node are handled separately)
/scripts/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.production
.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# storage (scraped data, backups, logs)
storage/

# temporary / debug files
tmp_root.html
*.png
*.jpg
*.jpeg

# claude / ai config
.claude/
AGENTS.md
CLAUDE.md

# screenshots (Russian filenames)
Скриншот*.png
ChatGPT*.png

.vercel
