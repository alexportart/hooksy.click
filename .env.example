# 🔑 API-ключи для AI генерации постов
# Чем выше в списке — тем выше приоритет

# OpenRouter — ОСНОВНОЙ
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openrouter/free

# Google Gemini - запасной
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# DeepInfra - БЕСПЛАТНЫЙ запасной
DEEPINFRA_API_KEY=your_deepinfra_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_MODEL=deepseek-chat

# HuggingFace - БЕСПЛАТНЫЙ
HUGGINGFACE_API_KEY=your_huggingface_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Cohere
COHERE_API_KEY=your_cohere_key_here
COHERE_MODEL=command-r-plus

# Sambanova
SAMBANOVA_API_KEY=your_sambanova_key_here
SAMBANOVA_MODEL=Meta-Llama-3.1-70B-Instruct

# Cerebras
CEREBRAS_API_KEY=your_cerebras_key_here
CEREBRAS_MODEL=llama3-70b

# Together AI
TOGETHER_API_KEY=your_together_key_here
TOGETHER_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# Groq - БЕСПЛАТНЫЙ, очень быстрый
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Настройки сервера
SERVER_HOST=0.0.0.0
SERVER_PORT=10000